# ── Database ─────────────────────────────────────────────
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/
MONGODB_URI=

# ── CORS ──────────────────────────────────────────────────
# Replace with your deployed frontend URL in production
CORS_ORIGIN=http://localhost:3000

# ── App settings ─────────────────────────────────────────
PORT=8000

# ── API Keys ──────────────────────────────────────────────
# Obtain this from https://console.deepgram.com/
DEEPGRAM_API_KEY=

# Obtain this from https://aistudio.google.com/
GIMINI_API_KEY=

# ── JWT ──────────────────────────────────────────────────
# Change this to a very long random string in production!
JWT_SECRET=your_super_secret_jwt_string_here_123456789
JWT_EXPIRES=7d

# ── Email / SMTP (for OTP) ───────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
